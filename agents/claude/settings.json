{
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "10000"
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.netrc)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/auth.json)",
      "Read(**/.ssh/**)"
    ]
  }
}
